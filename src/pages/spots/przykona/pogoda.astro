---
import { Layout } from "../../../components/Layout";
import { Head } from "../../../components/Head";

const navLinks = [
  { href: "/", label: "Kite Łódź", isActive: false },
  { href: "/spots/jeziorsko/", label: "Jeziorsko", isActive: false },
  { href: "/spots/przykona/", label: "Przykona", isActive: true },
  { href: "/kontakt", label: "Kontakt", isActive: false },
];
const subNav = [
  { href: "/spots/przykona/spoty", label: "Spoty", isActive: false },
  { href: "/spots/przykona/pogoda", label: "Pogoda", isActive: true },
];
---

<html lang="en" class="h-full">
  <head>
    <Head title="Pogoda - Przykona" />
  </head>
  <body class="h-full">
    <Layout navLinks={navLinks} desktopSubNav={subNav} mobileSubNav={subNav}>
      <div class="space-y-4">
        <div>
          <img
            id="meteo-forecast"
            data-row="409"
            data-col="213"
            src=""
            class="border-0 mb-4 w-full md:w-1/2 rounded-2xl"
          />
          <iframe
            class="w-full h-[200px] mb-4 rounded-2xl"
            src="https://embed.windy.com/embed.html?type=forecast&location=coordinates&detail=true&detailLat=52.004&detailLon=18.652&metricTemp=°C&metricRain=mm&metricWind=kt"
            frameborder="0"></iframe>
          <div class="rounded-2xl overflow-hidden">
            <div id="wg_fwdg_682747_100_1752307649736"></div>
          </div>
          <div data-weather-widget class="rounded-2xl"></div>
        </div>
      </div>
    </Layout>

    <script>
      import "../../../main.js";
    </script>
  </body>
</html>
