---
import { Layout } from "../../../components/Layout";
import { Head } from "../../../components/Head";

const navLinks = [
  { href: "/", label: "Kite Łódź", isActive: false },
  { href: "/spots/jeziorsko/", label: "Jeziorsko", isActive: false },
  { href: "/spots/przykona/", label: "Przykona", isActive: true },
  { href: "/kontakt", label: "Kontakt", isActive: false },
];

const desktopSubNav = [
  { href: "/spots/przykona/poludnie", label: "Południe", isActive: false },
  { href: "/spots/przykona/polnoc", label: "Północ", isActive: true },
];

const mobileSubNav = [];
---

<html lang="en" class="h-full">
  <head>
    <Head title="Północ - Przykona" />
  </head>
  <body class="h-full">
    <Layout
      navLinks={navLinks}
      desktopSubNav={desktopSubNav}
      mobileSubNav={mobileSubNav}
    >
      <div class="flex flex-col md:flex-row gap-8">
        <!-- Main content column -->
        <div class="md:w-2/3 order-2 md:order-2 space-y-4">
          <!-- Description Tile -->
          <div class="p-6 bg-white bg-opacity-70 rounded-2xl shadow-lg">
            <p class="text-gray-700 text-justify">
              Spot jest osłonięty ze wszystkich stron — czy to drzewami, czy
              trzciną. Mimo to jest wystarczająco dużo miejsca na rozłożenie
              latawca i linek. Do wody można się dostać jedynie przez małą
              przecinkę w trzcinach. Płytko jest dość daleko od brzegu — na
              tyle, że latawiec można wystartować z wody za trzciną. Dno jest
              muliste, a latem porośnięte, dlatego lepiej mieć buty. Dojazd jest
              mocno rozjeżdżony i po deszczu niskie auta mogą nie dojechać. Spot
              polecam jedynie wtedy, gdy wiatr wieje z SW i na Przykonie
              Południe jest off shore.
            </p>
          </div>

          <!-- Advantages Tile -->
          <div class="p-6 bg-white bg-opacity-70 rounded-2xl shadow-lg">
            <h3 class="text-xl mb-2">Zalety</h3>
            <ul class="list-disc pl-6 text-gray-700">
              <li>Przy wietrze SW kierunek jest side on shore</li>
            </ul>
          </div>

          <!-- Disadvantages Tile -->
          <div class="p-6 bg-white bg-opacity-70 rounded-2xl shadow-lg">
            <h3 class="text-xl mb-2">Wady</h3>
            <ul class="list-disc pl-6 text-gray-700">
              <li>Osłonięty drzewami i trzciną</li>
              <li>Mało miejsca do startu</li>
              <li>Muliste dno</li>
              <li>Trudny dojazd po deszczu</li>
            </ul>
          </div>

          <!-- Gallery Tile -->
          <div
            class="md:p-6 md:bg-white md:bg-opacity-70 md:rounded-2xl md:shadow-lg"
          >
            <div class="gallery grid grid-cols-1 md:grid-cols-2 gap-8">
              <div>
                <a
                  href="/assets/przykona-polnoc-start.webp"
                  class="block relative h-96 w-full bg-gray-200 rounded-2xl shadow-lg overflow-hidden"
                >
                  <img
                    src="/assets/przykona-polnoc-start.webp"
                    alt="Przykona Północ - start"
                    class="absolute top-0 left-0 w-full h-full object-cover"
                    loading="lazy"
                    onload="this.style.opacity=1"
                    style="opacity: 0"
                  />
                </a>
                <p class="mt-2 text-sm text-gray-600 text-center">
                  Północ — start
                </p>
              </div>
              <div>
                <a
                  href="/assets/przykona-polnoc-zejscie.webp"
                  class="block relative h-96 w-full bg-gray-200 rounded-2xl shadow-lg overflow-hidden"
                >
                  <img
                    src="/assets/przykona-polnoc-zejscie.webp"
                    alt="Przykona Północ - zejście"
                    class="absolute top-0 left-0 w-full h-full object-cover"
                    loading="lazy"
                    onload="this.style.opacity=1"
                    style="opacity: 0"
                  />
                </a>
                <p class="mt-2 text-sm text-gray-600 text-center">
                  Północ — zejście
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Sidebar / Info card -->
        <div class="md:w-1/3 order-1 md:order-1 space-y-4">
          <!-- Wind Directions Tile -->
          <div class="p-6 bg-white bg-opacity-70 rounded-2xl shadow-lg">
            <div class="flex justify-around items-center">
              <div>
                <p class="font-bold text-center">Kierunki wiatru:</p>
                <p class="text-center">W, SW</p>
              </div>
              <a
                href="https://www.google.com/maps/dir/?api=1&destination=52.007886099992014, 18.652700530662305"
                target="_blank"
                class="inline-block font-montserrat uppercase font-semibold bg-transparent border-2 border-textColor text-textColor py-2 px-4 rounded hover:bg-textColor hover:text-white transition-colors"
              >
                Dojazd
              </a>
            </div>
          </div>

          <!-- Map Tile -->
          <div
            class="md:p-6 md:bg-white md:bg-opacity-70 md:rounded-2xl md:shadow-lg"
          >
            <div class="space-y-6 lightbox-item">
              <a
                href="/assets/przykona-polnoc-mapa.webp"
                class="block relative bg-gray-200 rounded-2xl shadow-lg overflow-hidden"
              >
                <!-- This div creates the 4:3 aspect ratio -->
                <div style="padding-bottom: 75%"></div>
                <img
                  src="/assets/przykona-polnoc-mapa.webp"
                  alt="Mapa spotu Północ"
                  class="absolute top-0 left-0 w-full h-full object-cover"
                  loading="lazy"
                  onload="this.style.opacity=1"
                  style="opacity: 0"
                />
              </a>
              <div class="bg-slate-900 rounded-2xl p-3 mt-2">
                <div class="text-xs text-center">
                  <p class="flex justify-center items-center space-x-4">
                    <span class="text-gray-300"
                      ><span class="text-[#00feff]">■</span> Parking</span
                    >
                    <span class="text-gray-300"
                      ><span class="text-[#00fe00]">■</span> Strefa startu</span
                    >
                    <span class="text-gray-300"
                      ><span class="text-[#ea2a1d]">■</span> Strefa niebezpieczna</span
                    >
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Fullscreen Image Modal -->
      <div
        id="fullscreen-modal"
        class="fixed inset-0 bg-black flex items-center justify-center z-[1200] hidden"
      >
        <button
          id="close-fullscreen-modal"
          class="absolute top-4 right-4 text-white text-4xl font-bold focus:outline-none"
        >
          &times;
        </button>
        <img
          id="fullscreen-image"
          src=""
          alt="Fullscreen Image"
          class="max-w-[90%] max-h-[90%] object-contain"
        />
      </div>

      <script>
        import "../../../main.js";
      </script>
    </Layout>
  </body>
</html>
